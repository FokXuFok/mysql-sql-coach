# MySQL 连接
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=text

# AI 模型 (可选: deepseek / openai / ollama / mock)
AI_MODEL=deepseek

# DeepSeek (阿里百炼兼容模式)
DEEPSEEK_API_KEY=你的API key
DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# 通用
BENCHMARK_RUNS=3
LOG_LEVEL=INFO
